# ── Database ──────────────────────────────────────────────────────────
POSTGRES_DB=sentinel
POSTGRES_USER=sentinel
POSTGRES_PASSWORD=          # openssl rand -base64 24

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_PASSWORD=             # openssl rand -base64 24
# REDIS_TLS_CA_CERT=        # Path to CA cert if using private CA (e.g. /certs/redis-ca.crt)
REDIS_TLS_VERIFY=required   # "required" (verify cert) or "none" (encrypt only, skip verify)

# ── URLs ──────────────────────────────────────────────────────────────
# Public URL of the Sentinel auth service (used to build OAuth callback URLs)
BASE_URL=https://auth.example.com
# Public URL of the admin panel (redirects after admin login/logout)
ADMIN_URL=https://admin.example.com
# ALLOWED_HOSTS is derived from BASE_URL + ADMIN_URL automatically.
# Override only if you need additional hostnames (comma-separated).
# ALLOWED_HOSTS=

# Base CORS origins (comma-separated)
# Client app redirect URIs are automatically added at runtime.
# Only list origins here that aren't registered as client apps (e.g. admin panel).
CORS_ORIGINS=https://admin.example.com

# ── Security ──────────────────────────────────────────────────────────
SESSION_SECRET_KEY=         # python -c "import secrets; print(secrets.token_urlsafe(32))"
# Service apps are now managed via the admin panel (DB-based).
# Register service apps at /admin/service-apps after deploying.

# ── OAuth Providers (uncomment as needed) ─────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# ENTRA_TENANT_ID=

# ── Admin ─────────────────────────────────────────────────────────────
ADMIN_EMAILS=               # comma-separated emails auto-promoted to admin

# ── Token Lifetimes ──────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Container ─────────────────────────────────────────────────────────
SENTINEL_PORT=9003
ADMIN_PORT=9004
