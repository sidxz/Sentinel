{
  "name": "@sentinel-auth/nextjs",
  "version": "0.1.0",
  "type": "module",
  "description": "Sentinel Auth Next.js SDK — Edge Middleware + server helpers",
  "license": "MIT",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware.d.ts",
      "import": "./dist/middleware.js",
      "require": "./dist/middleware.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "next": "^14.0.0 || ^15.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "@sentinel-auth/js": "^0.1.0",
    "@sentinel-auth/react": "^0.1.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "@types/react": "^19.0.0",
    "@sentinel-auth/js": "file:../js",
    "@sentinel-auth/react": "file:../react"
  }
}
