{
  "name": "@sentinel-auth/js",
  "version": "0.9.0",
  "type": "module",
  "description": "Sentinel Auth SDK for JavaScript/TypeScript — browser auth client & server utilities",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sidxz/Sentinel",
    "directory": "sdks/js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "jose": "^5.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "happy-dom": "^20.8.3",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
