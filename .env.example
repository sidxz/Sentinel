# Database
DATABASE_URL=postgresql+asyncpg://identity:identity_dev@localhost:90001/identity

# Redis
REDIS_URL=redis://localhost:90002/0

# JWT keys (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2 providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft EntraID (optional)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=

# Service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=90003
BASE_URL=http://localhost:90003
FRONTEND_URL=http://localhost:3000

# Allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000
