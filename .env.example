# Database
DATABASE_URL=postgresql+asyncpg://identity:identity_dev@localhost:9001/identity

# Redis
REDIS_URL=redis://localhost:9002/0

# JWT keys (generate with: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem)
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2 providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Microsoft EntraID (optional)
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=

# Service
SERVICE_HOST=0.0.0.0
SERVICE_PORT=9003
# Public URL of the Sentinel auth service (used to build OAuth callback URLs)
BASE_URL=http://localhost:9003
# Public URL of the default frontend app (exposed in admin system settings)
FRONTEND_URL=http://localhost:3000

# Session secret (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SESSION_SECRET_KEY=

# Base CORS origins (comma-separated)
# Client app redirect URIs are automatically added at runtime.
# Only list origins here that aren't registered as client apps (e.g. admin panel).
CORS_ORIGINS=http://localhost:9004

# Security
COOKIE_SECURE=false                   # Set true in production (requires HTTPS)
# ALLOWED_HOSTS is derived from BASE_URL + ADMIN_URL automatically.
# Override only if you need additional hostnames (comma-separated).
# ALLOWED_HOSTS=
SERVICE_API_KEYS=                     # Comma-separated; empty = no enforcement (dev only)
