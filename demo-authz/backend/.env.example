# Sentinel service URL (must be running)
SENTINEL_URL=http://localhost:9003

# Service API key — create one at the Sentinel admin panel -> Service Apps -> Register Service
# Use service_name "team-notes" when registering, then paste the key here.
SERVICE_API_KEY=

# IdP JWKS URL for validating IdP tokens — handles key rotation automatically.
# Google: https://www.googleapis.com/oauth2/v3/certs
IDP_JWKS_URL=https://www.googleapis.com/oauth2/v3/certs

# Demo frontend URL (for CORS). In authz mode the frontend handles its own
# IdP login (e.g. Google Sign-In) and sends both tokens to this backend.
FRONTEND_URL=http://localhost:5174
